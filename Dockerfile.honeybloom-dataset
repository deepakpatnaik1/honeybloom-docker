# honeybloom-dataset: Qwen dataset generation
# Base: vastai/comfy:v0.16.4-cuda-13.1-py312
# Purpose: Generate 20-image training datasets using Qwen
#
# NOT INCLUDED: Models (download at runtime via startup script)

FROM vastai/comfy:v0.16.4-cuda-13.1-py312

# Pin ComfyUI to v0.16.4 (CUDA 12.4-12.6 compatible, JOB006 known-good)
WORKDIR /opt/workspace-internal/ComfyUI
RUN git checkout a7a6335be538f55faa2abf7404c9b8e970847d1f

# Activate venv and install core dependencies
RUN /venv/main/bin/pip install -r requirements.txt && \
    /venv/main/bin/pip install numpy==1.26.4

# Clone required custom nodes
WORKDIR /opt/workspace-internal/ComfyUI/custom_nodes

# KJNodes - SaveImageKJ and utilities
RUN git clone https://github.com/kijai/ComfyUI-KJNodes.git

# NOTE: TextEncodeQwenImageEditPlus is NATIVE to ComfyUI core - no custom repo needed

# Create model directories
RUN mkdir -p /opt/workspace-internal/ComfyUI/models/checkpoints \
             /opt/workspace-internal/ComfyUI/models/clip \
             /opt/workspace-internal/ComfyUI/models/vae \
             /opt/workspace-internal/ComfyUI/models/unet

WORKDIR /opt/workspace-internal/ComfyUI

# Default: start ComfyUI on port 18188
CMD ["/venv/main/bin/python", "main.py", "--listen", "0.0.0.0", "--port", "18188"]
